pipeline {

    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  nodeSelector:
    kubernetes.io/hostname: devops-cluster-worker2

  containers:
  - name: tools
    image: mycompany/jenkins-agent:latest
    command:
      - cat
    tty: true
'''
        }
    }

    environment {
        IMAGE = 'docker.io/keerthana2003bggowd/django-demo'
        TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    credentialsId: 'github-pat',
                    url: 'https://github.com/keerthana2003bggowda/django-demo.git'
            }
        }

        stage('Build') {
            steps {
                container('tools') {
                    sh 'docker build -t "$IMAGE:$TAG" -t "$IMAGE:latest" .'
                }
            }
        }

        stage('Push') {
            steps {
                container('tools') {
                    withCredentials([
                        usernamePassword(
                            credentialsId: 'dockerhub-creds',
                            usernameVariable: 'DOCKERHUB_USER',
                            passwordVariable: 'DOCKERHUB_PWD'
                        )
                    ]) {
                        sh 'echo "$DOCKERHUB_PWD" | docker login -u "$DOCKERHUB_USER" --password-stdin'
                        sh 'docker push "$IMAGE:$TAG"'
                        sh 'docker push "$IMAGE:latest"'
                    }
                }
            }
        }

        stage('K8s Deployment') {
            steps {
                container('tools') {
                    sh 'kubectl apply -f k8s-deploy.yaml'
                }
            }
        }
    }
}